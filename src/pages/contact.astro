---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Find Us – The Ferry Cafe | Felixstowe Ferry, Suffolk IP11 9RZ</title>
    <meta name="description" content="Find The Ferry Cafe at Felixstowe Ferry, Suffolk IP11 9RZ. Open Wed–Sun 10am–2pm. Call 01394 276305 or email hello@theferry.cafe." />
    <link rel="canonical" href="https://theferry.cafe/contact" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title"       content="Find Us – The Ferry Cafe, Felixstowe Ferry" />
    <meta property="og:description" content="Felixstowe Ferry, Suffolk IP11 9RZ. Open Wed–Sun 10am–2pm. 01394 276305." />
    <meta property="og:url"         content="https://theferry.cafe/contact" />
    <meta property="og:type"        content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",    "item": "https://theferry.cafe/" },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://theferry.cafe/contact" },
      ],
    })}</script>
  </head>

  <body class="flex flex-col min-h-screen font-sans bg-white text-gray-800">
    <Header />

    <main id="main-content" class="flex-grow">

      <!-- Page header -->
      <div class="bg-brand-navy text-white py-10 px-4">
        <div class="container mx-auto">
          <p class="text-sky-300 text-sm mb-1">
            <a href="/" class="hover:underline">Home</a> &rsaquo; Contact
          </p>
          <h1 class="text-3xl sm:text-4xl font-extrabold mb-2">Find Us</h1>
          <p class="text-sky-100 text-sm sm:text-base max-w-xl">
            We're right on the water at Felixstowe Ferry — hard to miss, worth the trip.
          </p>
        </div>
      </div>

      <div class="container mx-auto px-4 py-12">
        <div class="grid lg:grid-cols-2 gap-10 max-w-5xl mx-auto">

          <!-- ── LEFT: Contact details + Hours ── -->
          <div class="space-y-8">

            <!-- Address -->
            <section aria-labelledby="address-heading">
              <h2 id="address-heading" class="text-xs font-bold text-brand-navy uppercase tracking-widest mb-3">
                Address
              </h2>
              <address class="not-italic text-gray-700 leading-loose text-sm sm:text-base">
                <span class="font-semibold">The Ferry Cafe</span><br />
                Felixstowe Ferry<br />
                Felixstowe, Suffolk<br />
                IP11 9RZ
              </address>
              <a
                href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-primary hover:bg-sky-600 text-white text-sm font-semibold rounded-lg transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Open in Google Maps
              </a>
            </section>

            <!-- Phone & Email -->
            <section aria-labelledby="contact-heading">
              <h2 id="contact-heading" class="text-xs font-bold text-brand-navy uppercase tracking-widest mb-3">
                Phone &amp; Email
              </h2>
              <ul class="space-y-3 text-sm sm:text-base">
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                  <a href="tel:+441394276305" class="text-primary font-semibold hover:underline">
                    01394 276305
                  </a>
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  <a href="mailto:hello@theferry.cafe" class="text-primary font-semibold hover:underline">
                    hello@theferry.cafe
                  </a>
                </li>
              </ul>
            </section>

            <!-- Opening hours -->
            <section aria-labelledby="hours-heading">
              <h2 id="hours-heading" class="text-xs font-bold text-brand-navy uppercase tracking-widest mb-3">
                Opening Hours
              </h2>
              <table class="text-sm w-full max-w-xs">
                <tbody>
                  <tr class="border-b border-gray-100">
                    <td class="py-2 pr-6 font-medium text-gray-700">Wednesday</td>
                    <td class="py-2 text-gray-600">10am – 2pm</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-2 pr-6 font-medium text-gray-700">Thursday</td>
                    <td class="py-2 text-gray-600">10am – 2pm</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-2 pr-6 font-medium text-gray-700">Friday</td>
                    <td class="py-2 text-gray-600">10am – 2pm</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-2 pr-6 font-medium text-gray-700">Saturday</td>
                    <td class="py-2 text-gray-600">10am – 2pm</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-2 pr-6 font-medium text-gray-700">Sunday</td>
                    <td class="py-2 text-gray-600">10am – 2pm</td>
                  </tr>
                  <tr class="border-b border-gray-100">
                    <td class="py-2 pr-6 font-medium text-gray-400">Monday</td>
                    <td class="py-2 text-gray-400">Closed*</td>
                  </tr>
                  <tr>
                    <td class="py-2 pr-6 font-medium text-gray-400">Tuesday</td>
                    <td class="py-2 text-gray-400">Closed*</td>
                  </tr>
                </tbody>
              </table>
              <p class="text-xs text-gray-400 mt-2">* Open on bank holidays and during school holidays.</p>
            </section>

            <!-- Getting here -->
            <section aria-labelledby="getting-here-heading">
              <h2 id="getting-here-heading" class="text-xs font-bold text-brand-navy uppercase tracking-widest mb-3">
                Getting Here
              </h2>
              <ul class="space-y-2 text-sm text-gray-600">
                <li class="flex gap-2">
                  <span class="text-primary font-bold shrink-0">🚗</span>
                  <span><strong>By car:</strong> Follow the A154 to Felixstowe Ferry. Parking available directly adjacent to the cafe (charges may apply).</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-primary font-bold shrink-0">🚶</span>
                  <span><strong>On foot:</strong> A 3-mile coastal walk along the promenade from Felixstowe town centre, or a shorter stroll from Old Felixstowe.</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-primary font-bold shrink-0">⛵</span>
                  <span><strong>By boat:</strong> Seasonal foot ferry from Bawdsey Quay crosses directly to Felixstowe Ferry.</span>
                </li>
                <li class="flex gap-2">
                  <span class="text-primary font-bold shrink-0">🚽</span>
                  <span><strong>Facilities:</strong> Public toilets are located directly opposite the cafe.</span>
                </li>
              </ul>
            </section>
          </div>

          <!-- ── RIGHT: Map placeholder + Contact form ── -->
          <div class="space-y-8">

            <!-- Map placeholder -->
            <div class="rounded-xl overflow-hidden border border-gray-200 shadow-sm">
              <a
                href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
                target="_blank"
                rel="noopener noreferrer"
                class="block"
                aria-label="Open The Ferry Cafe location in Google Maps"
              >
                <!-- TODO: Replace this placeholder with a real embedded map.
                     Option 1 (free): Google Maps embed iframe
                     Option 2 (privacy-friendly): OpenStreetMap via iframe or map image
                     Example iframe:
                     <iframe
                       src="https://www.google.com/maps/embed?pb=..."
                       width="100%" height="300" style="border:0;" allowfullscreen loading="lazy"
                       referrerpolicy="no-referrer-when-downgrade"
                       title="Map showing The Ferry Cafe location"
                     ></iframe>
                -->
                <div class="bg-sky-100 h-64 flex flex-col items-center justify-center text-sky-700 gap-2 hover:bg-sky-200 transition-colors">
                  <svg class="w-10 h-10 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <p class="font-semibold text-sm">Felixstowe Ferry, IP11 9RZ</p>
                  <p class="text-xs text-sky-500">Click to open in Google Maps</p>
                </div>
              </a>
            </div>

            <!-- Contact form -->
            <section aria-labelledby="form-heading">
              <h2 id="form-heading" class="text-xs font-bold text-brand-navy uppercase tracking-widest mb-4">
                Send Us a Message
              </h2>

              <!--
                TODO: Activate this form with Formspree.
                1. Sign up free at https://formspree.io
                2. Create a new form and copy your form ID
                3. Replace YOUR_FORM_ID below with your actual form ID
                4. Remove the `pointer-events-none opacity-60` classes from the <form> tag
              -->

              <div class="relative">
                <div class="absolute inset-0 bg-white/60 backdrop-blur-sm rounded-xl z-10 flex items-center justify-center">
                  <div class="bg-sky-50 border border-sky-200 rounded-lg p-4 text-center text-sm text-sky-800 max-w-xs mx-4">
                    <p class="font-bold mb-1">Contact form coming soon</p>
                    <p>In the meantime, call us on
                      <a href="tel:+441394276305" class="underline font-semibold">01394 276305</a>
                      or email
                      <a href="mailto:hello@theferry.cafe" class="underline font-semibold">hello@theferry.cafe</a>.
                    </p>
                  </div>
                </div>

                <form
                  action="https://formspree.io/f/YOUR_FORM_ID"
                  method="POST"
                  class="space-y-4 opacity-30 pointer-events-none"
                  aria-hidden="true"
                >
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                    <input
                      id="name" name="name" type="text" autocomplete="name"
                      class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                      placeholder="Your name"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input
                      id="email" name="email" type="email" autocomplete="email"
                      class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                      placeholder="you@example.com"
                    />
                  </div>
                  <div>
                    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                    <textarea
                      id="message" name="message" rows="4"
                      class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary resize-none"
                      placeholder="Your message…"
                    ></textarea>
                  </div>
                  <button
                    type="submit"
                    class="w-full py-3 bg-primary hover:bg-sky-600 text-white font-bold rounded-lg transition-colors text-sm"
                  >
                    Send Message
                  </button>
                </form>
              </div>
            </section>

          </div>
        </div>
      </div>

      <!-- Review nudge -->
      <div class="bg-amber-50 border-t border-amber-100 py-10">
        <div class="container mx-auto px-4 text-center">
          <p class="text-2xl mb-2" aria-hidden="true">⭐⭐⭐⭐⭐</p>
          <h2 class="text-lg font-bold text-gray-800 mb-1">Had a great time?</h2>
          <p class="text-gray-500 text-sm mb-5 max-w-xs mx-auto">Help others find us — a quick Google review makes a huge difference to a small independent café.</p>
          <a href="https://search.google.com/local/writereview?placeid=ChIJIeBvYUN42UcRWsRJ8xkySJE"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-7 py-3 bg-[#4285F4] hover:bg-[#3367d6] text-white font-bold rounded-full shadow transition-colors text-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#fff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#fff" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#fff" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#fff" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Leave a Google Review
          </a>
        </div>
      </div>

    </main>

    <!-- Mobile sticky bar -->
    <div class="fixed bottom-0 inset-x-0 z-50 sm:hidden bg-white border-t border-gray-200 shadow-2xl"
         aria-label="Quick contact">
      <div class="grid grid-cols-2 divide-x divide-gray-200">
        <a href="tel:+441394276305"
           class="flex items-center justify-center gap-2 py-3.5 text-primary font-bold text-sm active:bg-sky-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call Us
        </a>
        <a href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-2 py-3.5 bg-primary text-white font-bold text-sm active:bg-sky-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Get Directions
        </a>
      </div>
    </div>
    <div class="h-14 sm:hidden" aria-hidden="true"></div>

    <Footer />
  </body>
</html>
