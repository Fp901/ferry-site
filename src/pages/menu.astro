---
import Layout from '../layouts/Layout.astro';
import { SITE, breadcrumbSchema } from '../lib/schema';

const sections = [
  {
    heading: "Breakfast",
    emoji: "🍳",
    note: "Served until midday",
    items: [
      { name: "Ferry Breakfast",                 desc: "Suffolk sausage, bacon, hash brown, beans, sautéed mushrooms, fried egg, toast & butter" },
      { name: "Vegetarian Breakfast",            desc: "Vegetarian sausage, hash brown, beans, sautéed mushrooms, fried egg, toast & butter" },
      { name: "Scrambled Eggs on Toast",         desc: "" },
      { name: "Heinz Baked Beans on Toast",      desc: "" },
      { name: "Scrambled Eggs on Toast with Smoked Bacon", desc: "" },
      { name: "Three Egg Omelette",              desc: "Choice of Suffolk ham, mature cheddar or mushroom, served with beans, toast & butter" },
    ],
  },
  {
    heading: "Artisan Breakfast Rolls",
    emoji: "🥖",
    note: "Served until midday · artisan baker's roll handcrafted by The Friendly Loaf Bakery, Bury St Edmunds",
    items: [
      { name: "Free Range Fried Egg",            desc: "" },
      { name: "Suffolk Bacon",                   desc: "" },
      { name: "Bacon & Egg",                     desc: "" },
      { name: "Suffolk Sausage",                 desc: "" },
      { name: "Sausage & Egg",                   desc: "" },
      { name: "Sausage & Bacon",                 desc: "" },
      { name: "Sausage, Bacon & Egg",            desc: "" },
      { name: "Vegetarian/Vegan Sausage",        desc: "" },
    ],
  },
  {
    heading: "Fish & Chips",
    emoji: "🐟",
    note: "Served from midday · all fish subject to availability · with garden peas & homemade tartare sauce",
    items: [
      { name: "Cod & Chips",                     desc: "" },
      { name: "Half Portion Cod & Chips",        desc: "" },
      { name: "Plaice & Chips",                  desc: "" },
      { name: "Haddock & Chips",                 desc: "" },
      { name: "Wholetail Scampi & Chips",        desc: "" },
      { name: "Grilled Sea Bass & Chips",        desc: "Subject to availability" },
    ],
  },
  {
    heading: "Brunch",
    emoji: "🍽️",
    note: "Served from midday",
    items: [
      { name: "Free Range Fried Eggs & Chips",   desc: "" },
      { name: "Home-cooked Suffolk Ham, Eggs & Chips", desc: "" },
      { name: "Suffolk Sausages, Chips & Beans", desc: "" },
      { name: "Suffolk Sausages, Eggs, Chips & Beans", desc: "" },
      { name: "Vegetarian Sausages, Chips & Beans", desc: "" },
      { name: "Vegetarian Sausages, Eggs, Chips & Beans", desc: "" },
      { name: "Three Egg Omelette",              desc: "Choice of Suffolk ham, mature cheddar or mushroom, served with chips & beans" },
    ],
  },
  {
    heading: "Large Artisan Baker's Rolls",
    emoji: "🥪",
    note: "Served from midday · artisan baker's roll handcrafted by The Friendly Loaf Bakery, Bury St Edmunds · served with chips",
    items: [
      { name: "Suffolk Pork Sausage",           desc: "" },
      { name: "Suffolk Smoked Back Bacon",      desc: "" },
      { name: "Home-cooked Ham, Salad & Mayonnaise", desc: "" },
      { name: "Home-cooked Ham & Cheese",       desc: "" },
      { name: "Cheddar Cheese & Chutney",       desc: "" },
      { name: "Tuna, Mayonnaise & Cucumber",    desc: "" },
      { name: "Bacon, Fresh Leaves, Tomato & Mayonnaise", desc: "" },
      { name: "Fish Fingers, Fresh Leaves & Tartare Sauce", desc: "" },
      { name: "Vegetarian Sausages, Red Onion Jam & Fresh Leaves", desc: "" },
      { name: "Luxury Prawn",                   desc: "In a prawn cocktail sauce with fresh leaves" },
      { name: "Seafood, Thousand Island Sauce & Fresh Leaves", desc: "Subject to availability" },
    ],
  },
  {
    heading: "Children's Meals",
    emoji: "🧒",
    note: "Served with chips, beans & a Fruit Shoot",
    items: [
      { name: "Chicken Nuggets",                desc: "" },
      { name: "Sausage",                        desc: "" },
      { name: "Fish Fingers",                   desc: "" },
      { name: "Heinz Baked Beans on Toast",     desc: "" },
    ],
  },
  {
    heading: "Sides",
    emoji: "🍟",
    note: "",
    items: [
      { name: "Chips",                          desc: "" },
      { name: "Cheesy Chips",                   desc: "" },
      { name: "Baker's White Buttered Roll",    desc: "" },
    ],
  },
  {
    heading: "Cakes & Desserts",
    emoji: "🍰",
    note: "Freshly baked cakes, selection changes daily, ask at the counter",
    items: [
      { name: "Homemade Cakes",                 desc: "A changing selection of freshly baked homemade cakes, ask for today's choice" },
    ],
  },
  {
    heading: "Hot Drinks",
    emoji: "☕",
    note: "From our Italian espresso machine · all teas served in mugs",
    items: [
      { name: "Breakfast Tea",                  desc: "" },
      { name: "Herbal Tea / Decaf Tea",         desc: "" },
      { name: "Espresso",                       desc: "" },
      { name: "Americano",                      desc: "" },
      { name: "Flat White",                     desc: "" },
      { name: "Cappuccino",                     desc: "" },
      { name: "Café Latte",                     desc: "" },
      { name: "Chai Latte",                     desc: "" },
      { name: "Mocha",                          desc: "" },
      { name: "Hot Chocolate",                  desc: "" },
      { name: "Luxury Hot Chocolate",           desc: "" },
      { name: "Coffee Syrups",                  desc: "" },
    ],
  },
  {
    heading: "Cold Drinks",
    emoji: "🥤",
    note: "",
    items: [
      { name: "Still Water",                    desc: "" },
      { name: "Sparkling Water",                desc: "" },
      { name: "Fruit Juice",                    desc: "Apple or orange" },
      { name: "Coke / Diet Coke / Fanta / Sprite Zero", desc: "" },
      { name: "Lipton Ice Tea",                 desc: "Lemon or peach" },
      { name: "Fruit Shoots",                   desc: "Apple & blackcurrant or orange" },
      { name: "Iced Latte",                     desc: "" },
    ],
  },
  {
    heading: "Alcohol",
    emoji: "🍺",
    note: "We're a fully licensed establishment · over-18s only · please drink responsibly",
    items: [
      { name: "Peroni",                         desc: "5% · 330ml" },
      { name: "Adnams Ghost Ship",              desc: "4.5% · 500ml" },
      { name: "Adnams Ghost Ship (low alcohol)", desc: "0.5% · 500ml" },
      { name: "Aspall Cyder",                   desc: "5.5% · 330ml" },
      { name: "Pinot Grigio",                   desc: "12% · 175ml" },
      { name: "White Grenache Rosé",            desc: "9.5% · 175ml" },
    ],
  },
];

// Menu schema built from the section data above, eligible for food/menu SERP
// features. Prices aren't published, so offers are intentionally omitted.
const menuSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "name": "The Ferry Cafe Menu",
  "url": `${SITE}/menu`,
  "hasMenuSection": sections.map(section => ({
    "@type": "MenuSection",
    "name": section.heading,
    "hasMenuItem": section.items.map(item => ({
      "@type": "MenuItem",
      "name": item.name,
      ...(item.desc ? { "description": item.desc } : {}),
    })),
  })),
};

const breadcrumbs = breadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Menu", path: "/menu" },
]);
---
<Layout
  title="Menu – The Ferry Cafe Felixstowe | Fish & Chips, Brunch & Breakfast"
  description="The Ferry Cafe menu: hand-battered fish & chips (cod, haddock, plaice & scampi), plus cooked breakfasts, brunch, large artisan baker's rolls, children's meals, homemade cakes & barista coffee. Felixstowe Ferry, Suffolk."
  canonical="/menu"
  schemas={[menuSchema, breadcrumbs]}
>
    <main id="main-content" class="flex-grow">

      <!-- Page header -->
      <div class="bg-brand-navy text-white py-10 px-4">
        <div class="container mx-auto">
          <p class="text-sky-300 text-sm mb-1">
            <a href="/" class="hover:underline">Home</a> &rsaquo; Menu
          </p>
          <h1 class="text-3xl sm:text-4xl font-extrabold mb-2">Our Menu</h1>
          <p class="text-sky-100 text-sm sm:text-base max-w-xl">
            Everything made with care at Felixstowe Ferry since 1953.
            Dine in or takeaway. <a href="tel:+441394276305" class="underline font-medium">Call us</a> to check today's specials.
          </p>
        </div>
      </div>

      <!-- Hours reminder -->
      <div class="bg-sky-50 border-b border-sky-100">
        <div class="container mx-auto px-4 py-3 flex flex-wrap gap-x-6 gap-y-1 text-sm text-sky-800">
          <span>
            <strong>Kitchen serves:</strong> Wed–Sun until 2pm (café open till 3pm)
          </span>
          <span class="text-sky-500">|</span>
          <span>Closed Mon &amp; Tue (open bank holiday Mondays)</span>
          <span class="text-sky-500">|</span>
          <span>Dine-in &amp; takeaway available</span>
        </div>
      </div>

      <!-- Menu sections -->
      <div class="container mx-auto px-4 py-10 space-y-14">

        {sections.map(section => (
          <section aria-labelledby={`section-${section.heading.toLowerCase().replace(/\s+/g, '-')}`}>
            <div class="flex items-baseline gap-3 mb-5 pb-3 border-b-2 border-sky-100">
              <span class="text-2xl" aria-hidden="true">{section.emoji}</span>
              <h2
                id={`section-${section.heading.toLowerCase().replace(/\s+/g, '-')}`}
                class="text-xl sm:text-2xl font-bold text-primary"
              >
                {section.heading}
              </h2>
              <span class="text-sm text-gray-400 italic">{section.note}</span>
            </div>

            <!-- Mobile: stacked cards | md+: table -->
            <div class="md:hidden space-y-3">
              {section.items.map(item => (
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <p class="font-bold text-gray-800">{item.name}</p>
                  <p class="text-sm text-gray-500 mt-0.5">{item.desc}</p>
                </div>
              ))}
            </div>

            <table class="hidden md:table w-full border-collapse text-sm">
              <tbody>
                {section.items.map((item, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-sky-50/50'}>
                    <td class="py-3 px-4 font-semibold text-gray-800 w-56 align-top border-b border-gray-100">
                      {item.name}
                    </td>
                    <td class="py-3 px-4 text-gray-500 align-top border-b border-gray-100">
                      {item.desc}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ))}

        <!-- Pricing note -->
        <aside class="bg-sky-50 border border-sky-200 rounded-xl p-5 text-sm text-sky-800 max-w-2xl">
          <p class="font-bold mb-1">Specials, prices &amp; availability</p>
          <p>
            We run <strong>seasonal specials that change from time to time</strong>. Ask at the
            counter or <a href="tel:+441394276305" class="underline font-medium">call us on 01394 276305</a>
            for today's specials. Prices vary and menu items are subject to seasonal availability;
            <a href="/contact" class="underline font-medium">visit the cafe</a> for the current price list.
          </p>
        </aside>

        <!-- Add more menu sections above this line as needed -->

        <!-- Full menu board scans -->
        <section aria-labelledby="menu-board-heading" class="pt-4">
          <h2 id="menu-board-heading" class="text-xl font-bold text-brand-navy mb-4">Full Menu Board</h2>
          <p class="text-sm text-gray-500 mb-5">Click to open full size.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <a href="/assets/ferry-cafe-menu-food.webp" target="_blank" rel="noopener" aria-label="Food menu board – open full size">
              <img
                src="/assets/ferry-cafe-menu-food.webp"
                alt="The Ferry Cafe food menu board – breakfast, fish & chips, brunch, large artisan baker's rolls, children's meals and sides"
                width="1280"
                height="909"
                loading="lazy"
                decoding="async"
                class="w-full rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow"
              />
            </a>
            <a href="/assets/ferry-cafe-menu-drinks.webp" target="_blank" rel="noopener" aria-label="Drinks menu board – open full size">
              <img
                src="/assets/ferry-cafe-menu-drinks.webp"
                alt="The Ferry Cafe drinks menu board – hot drinks, cold drinks and alcohol"
                width="1280"
                height="909"
                loading="lazy"
                decoding="async"
                class="w-full rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow"
              />
            </a>
          </div>
        </section>

      </div>
    </main>

    <!-- Mobile sticky bar -->
    <div class="fixed bottom-0 inset-x-0 z-50 sm:hidden bg-white border-t border-gray-200 shadow-2xl"
         aria-label="Quick contact">
      <div class="grid grid-cols-2 divide-x divide-gray-200">
        <a href="tel:+441394276305"
           class="flex items-center justify-center gap-2 py-3.5 text-primary font-bold text-sm active:bg-sky-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call Us
        </a>
        <a href="/contact"
           class="flex items-center justify-center gap-2 py-3.5 bg-primary text-white font-bold text-sm active:bg-sky-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Find Us
        </a>
      </div>
    </div>
    <div class="h-14 sm:hidden" aria-hidden="true"></div>
</Layout>
