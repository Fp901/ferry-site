---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    heading: "Breakfast",
    emoji: "🍳",
    note: "Served all day",
    items: [
      { name: "Full English Breakfast",  desc: "Locally sourced eggs, bacon, sausages, baked beans, grilled tomato, mushrooms & toast" },
      { name: "Veggie Breakfast",        desc: "Vegan sausages, eggs, baked beans, grilled tomato, mushrooms & toast" },
      { name: "Eggs on Toast",           desc: "Fried, scrambled or poached — your choice" },
      { name: "Bacon Bap",               desc: "Thick-cut back bacon in a soft white or brown roll" },
      { name: "Sausage Bap",             desc: "Two pork sausages in a soft roll with sauce of your choice" },
    ],
  },
  {
    heading: "Fish & Chips",
    emoji: "🐟",
    note: "Felixstowe Ferry's finest",
    items: [
      { name: "Cod & Chips",             desc: "Hand-battered fresh cod fillet with chunky chips & tartare sauce" },
      { name: "Haddock & Chips",         desc: "Hand-battered haddock with chunky chips & tartare sauce" },
      { name: "Scampi & Chips",          desc: "Breaded scampi with chunky chips & tartare sauce" },
      { name: "Chips",                   desc: "A generous portion of chunky chips — great with a side of mushy peas" },
    ],
  },
  {
    heading: "Seafood & Mains",
    emoji: "🦀",
    note: "Suffolk coastal produce",
    items: [
      { name: "Dressed Crab",            desc: "Local Suffolk crab dressed in the traditional way, served with bread & butter" },
      { name: "Grilled Cod",             desc: "Fresh grilled cod fillet with seasonal vegetables" },
      { name: "Seafood Platter",         desc: "A selection of local coastal seafood — ask your server for today's catch" },
      { name: "Chicken Parma",           desc: "Grilled chicken breast topped with ham, napoli sauce & melted cheese" },
      { name: "Sirloin Steak",           desc: "8oz sirloin, served with chunky chips & a choice of sauce" },
    ],
  },
  {
    heading: "Light Bites & Lunches",
    emoji: "🥗",
    note: "Ideal after a coastal walk",
    items: [
      { name: "Jacket Potato",           desc: "Oven-baked jacket potato with your choice of filling: cheese, beans, tuna mayo or coleslaw" },
      { name: "Fresh Salad",             desc: "Crisp seasonal salad with your choice of protein topping" },
      { name: "Baguettes & Sandwiches", desc: "Freshly made with a variety of fillings — ask at the counter" },
      { name: "Soup of the Day",         desc: "Homemade soup with a crusty roll — ask your server for today's selection" },
    ],
  },
  {
    heading: "Burgers",
    emoji: "🍔",
    note: "Including vegan options",
    items: [
      { name: "Classic Beef Burger",     desc: "6oz beef patty, lettuce, tomato, pickles & burger sauce in a brioche bun with chips" },
      { name: "Chicken Burger",          desc: "Grilled or crispy chicken breast with slaw & aioli in a brioche bun with chips" },
      { name: "Beetroot & Mushroom Burger", desc: "Vegan beetroot and mushroom patty with lettuce, tomato & vegan mayo — served with chips" },
    ],
  },
  {
    heading: "Cakes & Desserts",
    emoji: "🍰",
    note: "Baked fresh daily",
    items: [
      { name: "Homemade Cake",           desc: "Slice of today's homemade cake — ask your server for the daily selection" },
      { name: "Scone with Clotted Cream", desc: "Fresh-baked scone with clotted cream and strawberry jam" },
      { name: "Pudding of the Day",      desc: "Ask your server for our freshly made dessert selection" },
    ],
  },
  {
    heading: "Hot & Cold Drinks",
    emoji: "☕",
    note: "Including children's options",
    items: [
      { name: "Filter Coffee",           desc: "Freshly brewed — regular or large" },
      { name: "Cappuccino / Latte",      desc: "Espresso-based coffees made to order" },
      { name: "Tea",                     desc: "English breakfast tea — pot for one or two" },
      { name: "Soft Drinks",             desc: "Colas, lemonades, juices and cordials" },
      { name: "Beer & Wine",             desc: "A selection of beers and wines available — ask at the counter" },
    ],
  },
];
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Menu – The Ferry Cafe Felixstowe | Fish &amp; Chips, Breakfast &amp; More</title>
    <meta name="description" content="Browse The Ferry Cafe's menu: hand-battered fish & chips, full English breakfast, dressed crab, burgers, homemade cakes & more. Felixstowe Ferry, Suffolk." />
    <link rel="canonical" href="https://theferry.cafe/menu" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title"       content="Menu – The Ferry Cafe Felixstowe" />
    <meta property="og:description" content="Fish & chips, all-day breakfast, dressed crab, burgers, homemade cakes and more." />
    <meta property="og:url"         content="https://theferry.cafe/menu" />
    <meta property="og:type"        content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://theferry.cafe/" },
        { "@type": "ListItem", "position": 2, "name": "Menu",  "item": "https://theferry.cafe/menu" },
      ],
    })}</script>
  </head>

  <body class="flex flex-col min-h-screen font-sans bg-white text-gray-800">
    <Header />

    <main id="main-content" class="flex-grow">

      <!-- Page header -->
      <div class="bg-brand-navy text-white py-10 px-4">
        <div class="container mx-auto">
          <p class="text-sky-300 text-sm mb-1">
            <a href="/" class="hover:underline">Home</a> &rsaquo; Menu
          </p>
          <h1 class="text-3xl sm:text-4xl font-extrabold mb-2">Our Menu</h1>
          <p class="text-sky-100 text-sm sm:text-base max-w-xl">
            Everything made with care at Felixstowe Ferry since 1953.
            Dine in or takeaway — <a href="tel:+441394276305" class="underline font-medium">call us</a> to check today's specials.
          </p>
        </div>
      </div>

      <!-- Hours reminder -->
      <div class="bg-sky-50 border-b border-sky-100">
        <div class="container mx-auto px-4 py-3 flex flex-wrap gap-x-6 gap-y-1 text-sm text-sky-800">
          <span>
            <strong>Kitchen hours:</strong> Wed–Sun 10am–2pm
          </span>
          <span class="text-sky-500">|</span>
          <span>Closed Mon &amp; Tue (open school holidays)</span>
          <span class="text-sky-500">|</span>
          <span>Dine-in &amp; takeaway available</span>
        </div>
      </div>

      <!-- Menu sections -->
      <div class="container mx-auto px-4 py-10 space-y-14">

        {sections.map(section => (
          <section aria-labelledby={`section-${section.heading.toLowerCase().replace(/\s+/g, '-')}`}>
            <div class="flex items-baseline gap-3 mb-5 pb-3 border-b-2 border-sky-100">
              <span class="text-2xl" aria-hidden="true">{section.emoji}</span>
              <h2
                id={`section-${section.heading.toLowerCase().replace(/\s+/g, '-')}`}
                class="text-xl sm:text-2xl font-bold text-primary"
              >
                {section.heading}
              </h2>
              <span class="text-sm text-gray-400 italic">{section.note}</span>
            </div>

            <!-- Mobile: stacked cards | md+: table -->
            <div class="md:hidden space-y-3">
              {section.items.map(item => (
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <p class="font-bold text-gray-800">{item.name}</p>
                  <p class="text-sm text-gray-500 mt-0.5">{item.desc}</p>
                </div>
              ))}
            </div>

            <table class="hidden md:table w-full border-collapse text-sm">
              <tbody>
                {section.items.map((item, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-sky-50/50'}>
                    <td class="py-3 px-4 font-semibold text-gray-800 w-56 align-top border-b border-gray-100">
                      {item.name}
                    </td>
                    <td class="py-3 px-4 text-gray-500 align-top border-b border-gray-100">
                      {item.desc}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ))}

        <!-- Pricing note -->
        <aside class="bg-sky-50 border border-sky-200 rounded-xl p-5 text-sm text-sky-800 max-w-2xl">
          <p class="font-bold mb-1">Prices &amp; availability</p>
          <p>
            Prices and daily specials vary. Please
            <a href="tel:+441394276305" class="underline font-medium">call us on 01394 276305</a>
            or <a href="/contact" class="underline font-medium">visit the cafe</a> for the current
            price list. Menu items are subject to seasonal availability.
          </p>
        </aside>

        <!-- Add more menu sections above this line as needed -->

        <!-- Full menu board scans -->
        <section aria-labelledby="menu-board-heading" class="pt-4">
          <h2 id="menu-board-heading" class="text-xl font-bold text-brand-navy mb-4">Full Menu Board</h2>
          <p class="text-sm text-gray-500 mb-5">Click to open full size.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <a href="/assets/menu-p1.webp" target="_blank" rel="noopener" aria-label="Menu page 1 – open full size">
              <img
                src="/assets/menu-p1.webp"
                alt="The Ferry Cafe full menu board – page 1"
                width="800"
                height="1100"
                loading="lazy"
                decoding="async"
                class="w-full rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow"
              />
            </a>
            <a href="/assets/menu-p2.webp" target="_blank" rel="noopener" aria-label="Menu page 2 – open full size">
              <img
                src="/assets/menu-p2.webp"
                alt="The Ferry Cafe full menu board – page 2"
                width="800"
                height="1100"
                loading="lazy"
                decoding="async"
                class="w-full rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow"
              />
            </a>
          </div>
        </section>

      </div>
    </main>

    <!-- Mobile sticky bar -->
    <div class="fixed bottom-0 inset-x-0 z-50 sm:hidden bg-white border-t border-gray-200 shadow-2xl"
         aria-label="Quick contact">
      <div class="grid grid-cols-2 divide-x divide-gray-200">
        <a href="tel:+441394276305"
           class="flex items-center justify-center gap-2 py-3.5 text-primary font-bold text-sm active:bg-sky-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call Us
        </a>
        <a href="/contact"
           class="flex items-center justify-center gap-2 py-3.5 bg-primary text-white font-bold text-sm active:bg-sky-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Find Us
        </a>
      </div>
    </div>
    <div class="h-14 sm:hidden" aria-hidden="true"></div>

    <Footer />
  </body>
</html>
