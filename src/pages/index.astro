---
import Layout from '../layouts/Layout.astro';

// Minimal, deliberately-chosen photos (the two strongest shots only).
const photos = [
  { src: "/assets/food-fish-chips.webp", alt: "Hand-battered fish and chips at The Ferry Cafe, Felixstowe Ferry" },
  { src: "/assets/food-breakfast.webp",  alt: "Full English breakfast with seaside view at The Ferry Cafe, Felixstowe" },
];

const usp = [
  { icon: "🐟", title: "Fresh Fish & Chips",   text: "Hand-battered to order: cod, haddock, plaice & scampi" },
  { icon: "🌊", title: "River Deben Views",     text: "Terrace overlooking the estuary & sailing boats" },
  { icon: "🎵", title: "1950s Diner",           text: "Jukebox, vinyl records & retro American-diner charm" },
  { icon: "🐾", title: "Dog Friendly",          text: "Four-legged visitors always welcome" },
];

const menuHighlights = [
  { icon: "🐟", title: "Fish & Chips",          desc: "Hand-battered cod, haddock, plaice, scampi & grilled sea bass, with mushy peas & tartare. Served from midday" },
  { icon: "🍳", title: "Cooked Breakfast",      desc: "The Ferry Breakfast & veggie breakfast with locally sourced ingredients, served until midday" },
  { icon: "🥖", title: "Artisan Breakfast Rolls", desc: "Suffolk bacon, sausage & egg on a freshly baked roll, served until midday" },
  { icon: "🍽️", title: "Brunch",               desc: "Suffolk ham, eggs, sausages & omelettes with chips & beans, served from midday" },
  { icon: "🥪", title: "Baguettes & Rolls",     desc: "Freshly baked baguettes with chips, from the Suffolk Club to luxury prawn" },
  { icon: "🍰", title: "Homemade Cakes",        desc: "Freshly baked homemade cakes, the selection changes daily, so ask for today's choice" },
  { icon: "🥤", title: "Milkshakes & Coffee",   desc: "Luxury milkshakes, barista coffee from our Italian espresso machine & cold drinks" },
];

const summer = [
  "Open seven days a week right through the school summer holidays.",
  "Seasonal specials that change from time to time, ask for today's board.",
  "Takeaway fish & chips to enjoy on the shingle by the water.",
  "Dog bowls and a shady terrace for warm afternoons by the Deben.",
];

const nearby = [
  { title: "Coastal Walks",         text: "Shingle beach strolls towards Felixstowe or the foot ferry to Bawdsey" },
  { title: "Ferry Golf Club",       text: "Championship links golf right on the doorstep" },
  { title: "Water Sports",          text: "Sailing, windsurfing & paddleboarding on the Deben" },
  { title: "Landguard Fort",        text: "Historic Tudor artillery fort, an English Heritage site" },
  { title: "Felixstowe Museum",     text: "Local history and Felixstowe's naval heritage" },
  { title: "Foot Ferry to Bawdsey", text: "Cross the Deben for walks on the Bawdsey Marshes (seasonal)" },
];

const faqs = [
  { q: "What fish & chips do you serve?",          a: "Hand-battered cod, haddock, plaice and wholetail scampi, plus grilled sea bass, served from midday with mushy peas and tartare sauce (all fish subject to daily availability). A half portion of cod & chips is also available." },
  { q: "What are your opening hours?",            a: "Our kitchen is open Wednesday to Sunday, 10am–3pm. Closed Monday and Tuesday, except during school holidays when we open seven days a week." },
  { q: "What time do you serve breakfast?",        a: "Cooked breakfasts and artisan breakfast rolls are served until midday. From midday we switch to fish & chips, brunch and baguettes." },
  { q: "Is The Ferry Cafe dog friendly?",          a: "Absolutely, dogs are always welcome at our Felixstowe Ferry cafe, especially on the outdoor terrace overlooking the River Deben." },
  { q: "Do you offer takeaway?",                   a: "Yes, dine-in and takeaway fish & chips are both available. Our fish & chips are perfect down by the water on the shingle." },
  { q: "Is there parking at The Ferry Cafe?",      a: "Parking directly adjacent to the cafe at Felixstowe Ferry (charges may apply). Public toilets opposite." },
  { q: "Do you have vegetarian options?", a: "Yes, we serve a vegetarian breakfast, vegetarian sausage breakfast rolls, and a vegetarian sausage baguette with red onion jam. Just ask at the counter." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};
---
<Layout
  title="Fish & Chips at Felixstowe Ferry | The Ferry Cafe Since 1953"
  description="Famous hand-battered fish & chips at Felixstowe Ferry since 1953. Fresh cod, haddock, plaice & scampi by the River Deben. Dog friendly, dine in or takeaway. Kitchen open Wed–Sun 10am–3pm."
  canonical="/"
  ogType="restaurant"
  schemas={[faqSchema]}
>
  <!-- ══════════════════════════════════════════ TYPE-LED HERO -->
  <section
    class="relative flex items-center min-h-[86svh] bg-gradient-to-br from-brand-navy via-[#16566c] to-primary overflow-hidden"
    aria-label="The Ferry Cafe, Felixstowe Ferry"
  >
    <!-- Decorative estuary wave (pure SVG, no image weight) -->
    <svg class="absolute bottom-0 inset-x-0 w-full text-white/5" viewBox="0 0 1440 220" fill="none" preserveAspectRatio="none" aria-hidden="true">
      <path fill="currentColor" d="M0 120l60 13.3C120 147 240 173 360 165.3 480 157 600 117 720 112c120-5 240 25 360 40s240 5 300-2.7l60-7.3V220H0z"/>
    </svg>

    <div class="relative w-full px-5 py-24">
      <div class="container mx-auto max-w-3xl">
        <p class="inline-block mb-5 px-3 py-1 bg-white/15 backdrop-blur-sm border border-white/25 rounded-full text-white text-xs sm:text-sm font-semibold tracking-widest uppercase">
          Est. 1953 &middot; Felixstowe Ferry, Suffolk
        </p>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold leading-none tracking-tight text-white mb-4">
          The Ferry Café
        </h1>
        <p class="text-xl sm:text-2xl text-white/75 italic font-light mb-4">
          "a reel great plaice to catch a good time"
        </p>
        <p class="text-base sm:text-lg text-white/80 mb-9 max-w-xl leading-relaxed">
          <strong class="font-semibold text-white">Hand-battered fish &amp; chips</strong> by the water,
          with cooked breakfasts, brunch &amp; baguettes on the River Deben estuary since 1953.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/menu"
             class="px-7 py-3.5 bg-accent hover:bg-red-600 text-white font-bold rounded-full shadow-lg transition-colors">
            View Our Menu
          </a>
          <a href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
             target="_blank" rel="noopener noreferrer"
             class="px-7 py-3.5 bg-white/15 hover:bg-white/25 backdrop-blur-sm border border-white/35 text-white font-semibold rounded-full transition-colors">
            Get Directions
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════ HOURS + CONTACT STRIP -->
  <div class="bg-brand-navy text-white">
    <div class="container mx-auto px-4 py-4 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm sm:text-base text-center">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span><strong>Kitchen:</strong>&nbsp;Wed–Sun 10am–3pm &middot; Closed Mon &amp; Tue</span>
      </span>
      <span class="hidden sm:block text-white/30">|</span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <a href="tel:+441394276305" class="hover:underline font-medium">01394 276305</a>
      </span>
      <span class="hidden sm:block text-white/30">|</span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span>Felixstowe Ferry, Suffolk IP11 9RZ</span>
      </span>
    </div>
  </div>

  <main id="main-content" class="flex-grow">

    <!-- ══════════════════════════════════ TWO-UP PHOTO BAND (our best shots) -->
    <!-- Hidden on large viewports where the low-res photos stretch and blur -->
    <section aria-label="Food at The Ferry Cafe" class="lg:hidden">
      <div class="grid grid-cols-2 gap-0.5 bg-gray-200">
        <div class="h-56 sm:h-80 overflow-hidden group">
          <img
            src={photos[0].src} alt={photos[0].alt}
            width="800" height="600" loading="lazy" decoding="async"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
          />
        </div>
        <div class="h-56 sm:h-80 overflow-hidden group">
          <img
            src={photos[1].src} alt={photos[1].alt}
            width="800" height="600" loading="lazy" decoding="async"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
          />
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════ SOCIAL PROOF -->
    <div class="border-b border-gray-100 bg-white">
      <div class="container mx-auto px-4 py-5 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-600">
        <a href="https://search.google.com/local/writereview?placeid=ChIJIeBvYUN42UcRWsRJ8xkySJE"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-2 hover:text-gray-900 transition-colors">
          <span class="text-yellow-400 text-base">★★★★☆</span>
          <span><strong>4.2 / 5</strong> on Google &middot; <span class="text-gray-400">454 reviews</span></span>
        </a>
        <span class="hidden sm:block text-gray-200">|</span>
        <a href="https://www.tripadvisor.co.uk/Restaurant_Review-g503747-d4047876-Reviews-The_Ferry_Cafe-Felixstowe_Suffolk_East_Anglia_England.html"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-2 hover:text-gray-900 transition-colors">
          <span class="text-green-500 text-base">★★★★☆</span>
          <span><strong>3.6 / 5</strong> on TripAdvisor &middot; <span class="text-gray-400">270 reviews</span></span>
        </a>
        <span class="hidden sm:block text-gray-200">|</span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-navy" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          Serving Felixstowe Ferry since <strong>&nbsp;1953</strong>
        </span>
        <span class="hidden sm:block text-gray-200">|</span>
        <span>🐾 Dog friendly &middot; 🌊 Outdoor terrace &middot; 🎵 1950s diner</span>
      </div>
    </div>

    <!-- ══════════════════════════════════════ USP CARDS -->
    <section class="container mx-auto px-4 py-10" aria-label="Why visit The Ferry Cafe">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {usp.map(card => (
          <div class="bg-sky-50 rounded-2xl p-5 text-center shadow-sm hover:shadow-md transition-shadow">
            <div class="text-3xl mb-2" aria-hidden="true">{card.icon}</div>
            <h2 class="font-bold text-brand-navy text-sm sm:text-base">{card.title}</h2>
            <p class="text-xs sm:text-sm text-gray-500 mt-1 leading-snug">{card.text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════ MENU HIGHLIGHTS (text-led) -->
    <section class="bg-gray-50 py-14" aria-labelledby="menu-heading">
      <div class="container mx-auto px-4">
        <h2 id="menu-heading" class="text-3xl sm:text-4xl font-extrabold text-brand-navy mb-1">What We Serve</h2>
        <p class="text-gray-500 mb-10 text-sm sm:text-base">Proudly serving Felixstowe Ferry fish &amp; chips since 1953. Dine in or takeaway</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {menuHighlights.map(item => (
            <article class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5 flex gap-4">
              <div class="text-3xl shrink-0 leading-none" aria-hidden="true">{item.icon}</div>
              <div>
                <h3 class="font-bold text-brand-navy mb-1">{item.title}</h3>
                <p class="text-sm text-gray-500 leading-snug">{item.desc}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/menu"
             class="inline-block px-8 py-3.5 bg-brand-navy hover:bg-[#243f52] text-white font-bold rounded-full shadow-lg transition-colors">
            See the Full Menu &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════ OUR STORY -->
    <section class="py-16 overflow-hidden" aria-labelledby="story-heading">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-5xl mx-auto">
          <div>
            <h2 id="story-heading" class="text-3xl sm:text-4xl font-extrabold text-brand-navy mb-6 leading-tight">
              A Felixstowe Ferry<br />Landmark Since 1953
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              Perched at the mouth of the <strong>River Deben estuary</strong>, The Ferry Cafe has welcomed
              hungry visitors to <strong>Felixstowe Ferry</strong> since 1953. Step inside and you're
              transported back in time. Vintage vinyl records, theatrical posters and a
              <strong>1950s American-diner</strong> feel sit comfortably alongside the smell of
              fresh fish and proper coffee.
            </p>
            <p class="text-gray-600 leading-relaxed mb-8">
              Sit out on the terrace and watch sailboats navigate the Deben, or pull up a stool at
              the jukebox. Whether you've walked the beach, cycled the coast path, or arrived on the
              foot ferry from Bawdsey, we'll have something good waiting.
            </p>
            <a href="/about"
               class="inline-flex items-center gap-2 text-brand-navy font-bold hover:gap-3 transition-all">
              Our full story
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
          <!-- Single supporting photo (the jukebox/milkshake shows the 50s interior) -->
          <div class="relative">
            <div class="rounded-2xl overflow-hidden shadow-2xl aspect-[4/5]">
              <img
                src="/assets/food-milkshake.webp"
                alt="Strawberry milkshake beside the vintage jukebox at The Ferry Cafe, showing the 1950s diner interior"
                width="500" height="625" loading="lazy" decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl p-4 border border-gray-100">
              <img src="/assets/logo.webp" alt="The Ferry Cafe logo" width="80" height="80" class="w-20 h-20 object-contain" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════ THIS SUMMER (freshness block) -->
    <section class="bg-sky-50 border-y border-sky-100 py-14" aria-labelledby="summer-heading">
      <div class="container mx-auto px-4 max-w-3xl">
        <p class="text-accent font-bold text-xs uppercase tracking-widest mb-2">This Summer at the Ferry</p>
        <h2 id="summer-heading" class="text-3xl font-extrabold text-brand-navy mb-6">Summer on the Suffolk Coast</h2>
        <ul class="space-y-3">
          {summer.map(line => (
            <li class="flex gap-3 text-gray-600">
              <span class="text-primary mt-1 shrink-0">☀️</span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
        <p class="text-sm text-gray-500 mt-6">
          Planning a day at Felixstowe Ferry? Call ahead on
          <a href="tel:+441394276305" class="text-primary font-semibold hover:underline">01394 276305</a>
          to check today's specials and crab availability.
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════ FIND US -->
    <section class="bg-brand-navy text-white py-14" aria-labelledby="find-us-heading">
      <div class="container mx-auto px-4">
        <h2 id="find-us-heading" class="text-3xl font-extrabold mb-10 text-center">Find Us</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-4xl mx-auto">
          <div>
            <h3 class="font-bold text-sky-300 text-xs uppercase tracking-widest mb-3">Address</h3>
            <address class="not-italic text-sm leading-loose">
              The Ferry Cafe<br />Felixstowe Ferry<br />Felixstowe, Suffolk<br />IP11 9RZ
            </address>
            <a href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
               target="_blank" rel="noopener noreferrer"
               class="inline-block mt-4 text-xs font-semibold bg-white/15 hover:bg-white/25 px-4 py-2 rounded-full transition-colors">
              Open in Google Maps &nearr;
            </a>
          </div>
          <div>
            <h3 class="font-bold text-sky-300 text-xs uppercase tracking-widest mb-3">Opening Hours</h3>
            <table class="text-sm w-full">
              <tbody>
                <tr class="border-b border-white/10">
                  <td class="pr-4 py-1.5">Wednesday – Sunday</td>
                  <td class="font-bold">10am – 3pm</td>
                </tr>
                <tr>
                  <td class="pr-4 py-1.5 text-white/40">Monday – Tuesday</td>
                  <td class="text-white/40">Closed*</td>
                </tr>
              </tbody>
            </table>
            <p class="text-xs text-white/40 mt-2">* Open Mon &amp; Tue during school holidays</p>
          </div>
          <div>
            <h3 class="font-bold text-sky-300 text-xs uppercase tracking-widest mb-3">Get in Touch</h3>
            <p class="text-sm mb-4"><a href="tel:+441394276305" class="hover:underline font-semibold">01394 276305</a></p>
            <p class="text-xs text-white/50">Parking adjacent to the cafe.<br />Public toilets opposite.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════ NEARBY ACTIVITIES -->
    <section class="container mx-auto px-4 py-14" aria-labelledby="nearby-heading">
      <h2 id="nearby-heading" class="text-3xl font-extrabold text-brand-navy mb-2">Make a Day of It</h2>
      <p class="text-gray-500 mb-8 text-sm sm:text-base">Felixstowe Ferry is the perfect base for a day on the Suffolk coast.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {nearby.map(item => (
          <div class="flex gap-3 p-4 bg-sky-50 rounded-2xl hover:bg-sky-100 transition-colors">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
            <div>
              <h3 class="font-bold text-brand-navy text-sm">{item.title}</h3>
              <p class="text-xs text-gray-500 mt-0.5 leading-snug">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════ FAQ -->
    <section class="bg-gray-50 py-14" aria-labelledby="faq-heading">
      <div class="container mx-auto px-4 max-w-2xl">
        <h2 id="faq-heading" class="text-3xl font-extrabold text-brand-navy mb-8 text-center">FAQs</h2>
        <dl class="space-y-6">
          {faqs.map(item => (
            <div class="border-b border-gray-200 pb-5">
              <dt class="font-bold text-brand-navy mb-1">{item.q}</dt>
              <dd class="text-sm text-gray-600 leading-relaxed">{item.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ══════════════════════════════════ REVIEW CTA -->
    <section class="py-14 bg-amber-50 border-t border-amber-100" aria-label="Leave a Google review">
      <div class="container mx-auto px-4 text-center">
        <p class="text-3xl mb-3" aria-hidden="true">⭐⭐⭐⭐⭐</p>
        <h2 class="text-2xl font-extrabold text-gray-800 mb-2">Enjoyed your visit?</h2>
        <p class="text-gray-500 mb-7 max-w-sm mx-auto text-sm leading-relaxed">
          A Google review means the world to a small independent café. It takes 30 seconds and helps other visitors find us.
        </p>
        <a href="https://search.google.com/local/writereview?placeid=ChIJIeBvYUN42UcRWsRJ8xkySJE"
           target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-3 px-8 py-3.5 bg-[#4285F4] hover:bg-[#3367d6] text-white font-bold rounded-full shadow-lg transition-colors text-sm">
          <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#fff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#fff" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#fff" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
