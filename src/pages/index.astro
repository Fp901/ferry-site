---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const photos = [
  { src: "/assets/food-fish-chips.webp",     alt: "Hand-battered fish and chips at The Ferry Cafe, Felixstowe Ferry",    span: "lg:col-span-2 lg:row-span-2" },
  { src: "/assets/food-breakfast.webp",      alt: "Full English breakfast with seaside view at The Ferry Cafe",            span: "" },
  { src: "/assets/food-milkshake.webp",      alt: "Strawberry milkshake beside the jukebox at The Ferry Cafe",            span: "" },
  { src: "/assets/food-burger.webp",         alt: "Burger and chips with jukebox at The Ferry Cafe, Felixstowe",          span: "" },
  { src: "/assets/food-baguette.webp",       alt: "Prawn marie rose baguette at The Ferry Cafe, Felixstowe Ferry",        span: "" },
  { src: "/assets/food-breakfast-roll.webp", alt: "Bacon and egg breakfast roll at The Ferry Cafe, Felixstowe",           span: "" },
];

const usp = [
  { icon: "🐟", title: "Fresh Fish & Chips",    text: "Hand-battered to order, Felixstowe Ferry's finest" },
  { icon: "🌊", title: "River Deben Views",      text: "Terrace overlooking the estuary & sailing boats" },
  { icon: "🎵", title: "1950s Diner Vibes",      text: "Jukebox, vinyl records & retro American diner decor" },
  { icon: "🐾", title: "Dog Friendly",           text: "Four-legged visitors always welcome" },
];

const menuHighlights = [
  { title: "Fish & Chips",           desc: "Hand-battered fresh fish with chunky chips — the Felixstowe Ferry classic",   img: "/assets/food-fish-chips.webp",     alt: "Fresh fish and chips at The Ferry Cafe, Felixstowe Ferry" },
  { title: "Full English Breakfast", desc: "Locally sourced eggs, bacon, sausages & all the trimmings with a seaside view", img: "/assets/food-breakfast.webp",      alt: "Full English breakfast at The Ferry Cafe, Felixstowe" },
  { title: "Breakfast Roll",         desc: "Bacon & egg in a soft roll with a mug of tea — the perfect coastal morning",  img: "/assets/food-breakfast-roll.webp", alt: "Bacon and egg breakfast roll at The Ferry Cafe" },
  { title: "Burgers",                desc: "Including veggie options — served beside the jukebox with chunky chips",      img: "/assets/food-burger.webp",         alt: "Burger at The Ferry Cafe, Felixstowe" },
  { title: "Prawn Baguette",         desc: "Prawn marie rose on a fresh baguette, served on newspaper with fries",       img: "/assets/food-baguette.webp",       alt: "Prawn marie rose baguette at The Ferry Cafe, Felixstowe Ferry" },
  { title: "Milkshakes & Drinks",    desc: "Handmade milkshakes, barista coffee and cold drinks for all ages",           img: "/assets/food-milkshake.webp",      alt: "Strawberry milkshake at The Ferry Cafe, Felixstowe" },
];

const nearby = [
  { title: "Coastal Walks",         text: "Shingle beach strolls towards Felixstowe or the foot ferry to Bawdsey" },
  { title: "Ferry Golf Club",       text: "Championship links golf right on the doorstep" },
  { title: "Water Sports",          text: "Sailing, windsurfing & paddleboarding on the Deben" },
  { title: "Landguard Fort",        text: "Historic Tudor artillery fort — English Heritage site" },
  { title: "Felixstowe Museum",     text: "Local history and Felixstowe's naval heritage" },
  { title: "Foot Ferry to Bawdsey", text: "Cross the Deben for walks on the Bawdsey Marshes (seasonal)" },
];

const faqs = [
  { q: "What are your opening hours?",           a: "Wednesday to Sunday, 10am–2pm. Closed Monday and Tuesday, but open on bank holidays and during school holidays." },
  { q: "Is The Ferry Cafe dog friendly?",         a: "Absolutely — dogs always welcome, especially on our outdoor terrace overlooking the River Deben." },
  { q: "Do you offer takeaway?",                  a: "Yes — dine-in and takeaway both available. Our fish & chips are perfect by the water." },
  { q: "Is there parking at The Ferry Cafe?",     a: "Parking directly adjacent to the cafe at Felixstowe Ferry (charges may apply). Public toilets opposite." },
  { q: "Do you have vegetarian or vegan options?",a: "Yes — veggie sausages, vegetable lasagna, and a beetroot & mushroom burger among others." },
];

const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "The Ferry Cafe",
  "description": "Iconic 1950s-themed seaside café at Felixstowe Ferry serving fresh fish & chips, all-day breakfasts, dressed crab and homemade cakes with views over the River Deben estuary. Est. 1953.",
  "url": "https://theferry.cafe",
  "telephone": "+441394276305",
  "email": "hello@theferry.cafe",
  "address": { "@type": "PostalAddress", "streetAddress": "Felixstowe Ferry", "addressLocality": "Felixstowe", "addressRegion": "Suffolk", "postalCode": "IP11 9RZ", "addressCountry": "GB" },
  "geo": { "@type": "GeoCoordinates", "latitude": 51.9664, "longitude": 1.3765 },
  "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "10:00", "closes": "14:00" }],
  "servesCuisine": ["British","Seafood","Breakfast"],
  "priceRange": "££",
  "hasMap": "https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ",
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Dog Friendly",    "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Outdoor Seating", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Takeaway",        "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Parking",         "value": true },
  ],
  "menu": "https://theferry.cafe/menu",
  "foundingDate": "1953",
  "image": "https://theferry.cafe/assets/food-fish-chips.webp",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4", "reviewCount": "958", "bestRating": "5", "worstRating": "1" },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
};
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Ferry Cafe Felixstowe | Fish &amp; Chips, Breakfast &amp; River Views</title>
    <meta name="description" content="Felixstowe Ferry's favourite seaside café since 1953. Fresh fish & chips, all-day breakfasts, dressed crab & homemade cakes. Open Wed–Sun 10am–2pm. Dog friendly." />
    <meta name="keywords" content="ferry cafe felixstowe, felixstowe ferry cafe, fish and chips felixstowe ferry, seaside cafe suffolk, dressed crab suffolk, dog friendly cafe felixstowe, river deben cafe" />
    <link rel="canonical" href="https://theferry.cafe/" />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="GB-SFK" />
    <meta name="geo.placename" content="Felixstowe, Suffolk" />
    <meta name="geo.position" content="51.9664;1.3765" />
    <meta name="ICBM" content="51.9664, 1.3765" />
    <meta property="og:type"        content="restaurant" />
    <meta property="og:site_name"   content="The Ferry Cafe" />
    <meta property="og:locale"      content="en_GB" />
    <meta property="og:title"       content="The Ferry Cafe Felixstowe | Fish & Chips & River Views Since 1953" />
    <meta property="og:description" content="Fresh fish & chips, all-day breakfasts, dressed crab & homemade cakes at Felixstowe Ferry. Dog friendly. Open Wed–Sun 10am–2pm." />
    <meta property="og:url"         content="https://theferry.cafe/" />
    <meta property="og:image"       content="https://theferry.cafe/assets/food-fish-chips.webp" />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="The Ferry Cafe – Felixstowe Ferry, Suffolk" />
    <meta name="twitter:description" content="Fresh fish & chips, all-day breakfasts & River Deben views since 1953. Open Wed–Sun 10am–2pm." />
    <meta name="twitter:image"       content="https://theferry.cafe/assets/food-fish-chips.webp" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Preload hero image for fastest LCP -->
    <link rel="preload" as="image" href="/assets/food-fish-chips.webp" />
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </head>

  <body class="flex flex-col min-h-screen font-sans bg-white text-gray-800">
    <Header />

    <!-- ══════════════════════════════════════════ CINEMATIC HERO -->
    <section
      class="relative min-h-[100svh] flex items-end bg-cover bg-center"
      style="background-image: url('/assets/food-fish-chips.webp');"
      aria-label="The Ferry Cafe, Felixstowe Ferry"
    >
      <!-- Gradient: subtle at top, dramatic at bottom for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/35 to-black/10" aria-hidden="true"></div>

      <!-- Hero content — anchored to bottom -->
      <div class="relative w-full px-5 pb-20 sm:pb-24">
        <div class="container mx-auto max-w-3xl">
          <p class="inline-block mb-4 px-3 py-1 bg-white/15 backdrop-blur-sm border border-white/25 rounded-full text-white text-xs sm:text-sm font-semibold tracking-widest uppercase">
            Est. 1953 &middot; Felixstowe Ferry, Suffolk
          </p>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold leading-none tracking-tight text-white mb-3">
            The Ferry Café
          </h1>
          <p class="text-xl sm:text-2xl text-white/70 italic font-light mb-3">
            "a reel great plaice to catch a good time"
          </p>
          <p class="text-base sm:text-lg text-white/65 mb-8 max-w-xl leading-relaxed">
            Fresh fish &amp; chips, all-day breakfasts &amp; dressed crab —<br class="hidden sm:block" />
            on the River Deben estuary since 1953
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/menu"
               class="px-7 py-3.5 bg-accent hover:bg-red-600 text-white font-bold rounded-full shadow-lg transition-colors">
              View Our Menu
            </a>
            <a href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
               target="_blank" rel="noopener noreferrer"
               class="px-7 py-3.5 bg-white/15 hover:bg-white/25 backdrop-blur-sm border border-white/35 text-white font-semibold rounded-full transition-colors">
              Get Directions
            </a>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/40 animate-bounce" aria-hidden="true">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </section>

    <!-- ══════════════════════════════════ HOURS + CONTACT STRIP -->
    <div class="bg-brand-navy text-white">
      <div class="container mx-auto px-4 py-4 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm sm:text-base text-center">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span><strong>Wed–Sun</strong>&nbsp;10am–2pm &middot; Closed Mon &amp; Tue</span>
        </span>
        <span class="hidden sm:block text-white/30">|</span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href="tel:+441394276305" class="hover:underline font-medium">01394 276305</a>
        </span>
        <span class="hidden sm:block text-white/30">|</span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>Felixstowe Ferry, Suffolk IP11 9RZ</span>
        </span>
      </div>
    </div>

    <main id="main-content" class="flex-grow">

      <!-- ══════════════════════════════════ PHOTO MOSAIC (edge-to-edge) -->
      <section aria-label="Food and atmosphere at The Ferry Cafe">
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-0.5 bg-gray-200">
          <!-- Fish & chips — large, spans 2 cols + 2 rows on desktop -->
          <div class="lg:col-span-2 lg:row-span-2 h-64 sm:h-80 lg:h-auto overflow-hidden group">
            <img
              src="/assets/food-fish-chips.webp"
              alt={photos[0].alt}
              width="800" height="600"
              loading="lazy" decoding="async"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
            />
          </div>
          <!-- Breakfast — top right -->
          <div class="h-64 sm:h-80 overflow-hidden group">
            <img src="/assets/food-breakfast.webp"      alt={photos[1].alt} width="400" height="500" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <!-- Milkshake — bottom right -->
          <div class="h-64 sm:h-80 overflow-hidden group">
            <img src="/assets/food-milkshake.webp"      alt={photos[2].alt} width="400" height="500" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <!-- Row 2: three equal on desktop -->
          <div class="h-52 sm:h-64 overflow-hidden group">
            <img src="/assets/food-burger.webp"         alt={photos[3].alt} width="400" height="400" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <div class="h-52 sm:h-64 overflow-hidden group">
            <img src="/assets/food-baguette.webp"       alt={photos[4].alt} width="400" height="400" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <div class="h-52 sm:h-64 overflow-hidden group">
            <img src="/assets/food-breakfast-roll.webp" alt={photos[5].alt} width="400" height="400" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════════════════ SOCIAL PROOF -->
      <div class="border-b border-gray-100 bg-white">
        <div class="container mx-auto px-4 py-5 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-600">
          <a href="https://search.google.com/local/writereview?placeid=ChIJIeBvYUN42UcRWsRJ8xkySJE"
             target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 hover:text-gray-900 transition-colors">
            <span class="text-yellow-400 text-base">★★★★☆</span>
            <span><strong>4.2 / 5</strong> on Google &middot; <span class="text-gray-400">448 reviews</span></span>
          </a>
          <span class="hidden sm:block text-gray-200">|</span>
          <a href="https://www.tripadvisor.co.uk/Restaurant_Review-g503747-d4047876-Reviews-The_Ferry_Cafe-Felixstowe_Suffolk_East_Anglia_England.html"
             target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 hover:text-gray-900 transition-colors">
            <span class="text-green-500 text-base">★★★★☆</span>
            <span><strong>4 / 5</strong> on TripAdvisor &middot; <span class="text-gray-400">958+ reviews</span></span>
          </a>
          <span class="hidden sm:block text-gray-200">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-navy" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            Serving Felixstowe Ferry since <strong>&nbsp;1953</strong>
          </span>
          <span class="hidden sm:block text-gray-200">|</span>
          <span>🐾 Dog friendly &middot; 🌊 Outdoor terrace &middot; 🎵 1950s diner</span>
        </div>
      </div>

      <!-- ══════════════════════════════════════ USP CARDS -->
      <section class="container mx-auto px-4 py-10" aria-label="Why visit The Ferry Cafe">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {usp.map(card => (
            <div class="bg-sky-50 rounded-2xl p-5 text-center shadow-sm hover:shadow-md transition-shadow">
              <div class="text-3xl mb-2" aria-hidden="true">{card.icon}</div>
              <h2 class="font-bold text-brand-navy text-sm sm:text-base">{card.title}</h2>
              <p class="text-xs sm:text-sm text-gray-500 mt-1 leading-snug">{card.text}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ══════════════════════════════════ MENU HIGHLIGHTS -->
      <section class="bg-gray-50 py-14" aria-labelledby="menu-heading">
        <div class="container mx-auto px-4">
          <h2 id="menu-heading" class="text-3xl sm:text-4xl font-extrabold text-brand-navy mb-1">What We Serve</h2>
          <p class="text-gray-500 mb-10 text-sm sm:text-base">Proudly serving Felixstowe Ferry since 1953 — dine in or takeaway</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {menuHighlights.map(item => (
              <article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5 group">
                <div class="overflow-hidden h-48">
                  <img
                    src={item.img}
                    alt={item.alt}
                    width="400" height="260"
                    loading="lazy" decoding="async"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-bold text-brand-navy mb-1">{item.title}</h3>
                  <p class="text-sm text-gray-500 leading-snug">{item.desc}</p>
                </div>
              </article>
            ))}
          </div>
          <div class="mt-10 text-center">
            <a href="/menu"
               class="inline-block px-8 py-3.5 bg-brand-navy hover:bg-[#243f52] text-white font-bold rounded-full shadow-lg transition-colors">
              See the Full Menu &rarr;
            </a>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════ OUR STORY -->
      <section class="py-16 overflow-hidden" aria-labelledby="story-heading">
        <div class="container mx-auto px-4">
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-5xl mx-auto">
            <div>
              <h2 id="story-heading" class="text-3xl sm:text-4xl font-extrabold text-brand-navy mb-6 leading-tight">
                A Felixstowe Ferry<br />Landmark Since 1953
              </h2>
              <p class="text-gray-600 leading-relaxed mb-4">
                Perched at the mouth of the <strong>River Deben estuary</strong>, The Ferry Cafe has welcomed
                hungry visitors to <strong>Felixstowe Ferry</strong> since 1953. Step inside and you're
                transported back in time — vintage vinyl records, theatrical posters and a
                <strong>1950s American-diner</strong> feel sit comfortably alongside the smell of
                fresh fish and proper coffee.
              </p>
              <p class="text-gray-600 leading-relaxed mb-8">
                Sit out on the terrace and watch sailboats navigate the Deben, or pull up a stool at
                the jukebox. Whether you've walked the beach, cycled the coast path, or arrived on the
                foot ferry from Bawdsey — we'll have something good waiting.
              </p>
              <a href="/about"
                 class="inline-flex items-center gap-2 text-brand-navy font-bold hover:gap-3 transition-all">
                Our full story
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
            <!-- Jukebox / milkshake photo — shows the 50s interior perfectly -->
            <div class="relative">
              <div class="rounded-2xl overflow-hidden shadow-2xl aspect-[4/5]">
                <img
                  src="/assets/food-milkshake.webp"
                  alt="Strawberry milkshake beside the vintage jukebox at The Ferry Cafe, showing the 1950s diner interior"
                  width="500" height="625"
                  loading="lazy" decoding="async"
                  class="w-full h-full object-cover"
                />
              </div>
              <!-- Floating badge -->
              <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl p-4 border border-gray-100">
                <img src="/assets/logo.webp" alt="The Ferry Cafe logo" width="80" height="80" class="w-20 h-20 object-contain" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════ FIND US -->
      <section class="bg-brand-navy text-white py-14" aria-labelledby="find-us-heading">
        <div class="container mx-auto px-4">
          <h2 id="find-us-heading" class="text-3xl font-extrabold mb-10 text-center">Find Us</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-4xl mx-auto">
            <div>
              <h3 class="font-bold text-sky-300 text-xs uppercase tracking-widest mb-3">Address</h3>
              <address class="not-italic text-sm leading-loose">
                The Ferry Cafe<br />Felixstowe Ferry<br />Felixstowe, Suffolk<br />IP11 9RZ
              </address>
              <a href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
                 target="_blank" rel="noopener noreferrer"
                 class="inline-block mt-4 text-xs font-semibold bg-white/15 hover:bg-white/25 px-4 py-2 rounded-full transition-colors">
                Open in Google Maps &nearr;
              </a>
            </div>
            <div>
              <h3 class="font-bold text-sky-300 text-xs uppercase tracking-widest mb-3">Opening Hours</h3>
              <table class="text-sm w-full">
                <tbody>
                  <tr class="border-b border-white/10">
                    <td class="pr-4 py-1.5">Wednesday – Sunday</td>
                    <td class="font-bold">10am – 2pm</td>
                  </tr>
                  <tr>
                    <td class="pr-4 py-1.5 text-white/40">Monday – Tuesday</td>
                    <td class="text-white/40">Closed*</td>
                  </tr>
                </tbody>
              </table>
              <p class="text-xs text-white/40 mt-2">* Open bank holidays &amp; school holidays</p>
            </div>
            <div>
              <h3 class="font-bold text-sky-300 text-xs uppercase tracking-widest mb-3">Get in Touch</h3>
              <p class="text-sm mb-2"><a href="tel:+441394276305" class="hover:underline font-semibold">01394 276305</a></p>
              <p class="text-sm mb-4"><a href="mailto:hello@theferry.cafe" class="hover:underline">hello@theferry.cafe</a></p>
              <p class="text-xs text-white/50">Parking adjacent to the cafe.<br />Public toilets opposite.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════ NEARBY ACTIVITIES -->
      <section class="container mx-auto px-4 py-14" aria-labelledby="nearby-heading">
        <h2 id="nearby-heading" class="text-3xl font-extrabold text-brand-navy mb-2">Make a Day of It</h2>
        <p class="text-gray-500 mb-8 text-sm sm:text-base">Felixstowe Ferry is the perfect base for a day on the Suffolk coast.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {nearby.map(item => (
            <div class="flex gap-3 p-4 bg-sky-50 rounded-2xl hover:bg-sky-100 transition-colors">
              <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
              <div>
                <h3 class="font-bold text-brand-navy text-sm">{item.title}</h3>
                <p class="text-xs text-gray-500 mt-0.5 leading-snug">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ══════════════════════════════════════════════ FAQ -->
      <section class="bg-gray-50 py-14" aria-labelledby="faq-heading">
        <div class="container mx-auto px-4 max-w-2xl">
          <h2 id="faq-heading" class="text-3xl font-extrabold text-brand-navy mb-8 text-center">FAQs</h2>
          <dl class="space-y-6">
            {faqs.map(item => (
              <div class="border-b border-gray-200 pb-5">
                <dt class="font-bold text-brand-navy mb-1">{item.q}</dt>
                <dd class="text-sm text-gray-600 leading-relaxed">{item.a}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>

      <!-- ══════════════════════════════════ REVIEW CTA -->
      <section class="py-14 bg-amber-50 border-t border-amber-100" aria-label="Leave a Google review">
        <div class="container mx-auto px-4 text-center">
          <p class="text-3xl mb-3" aria-hidden="true">⭐⭐⭐⭐⭐</p>
          <h2 class="text-2xl font-extrabold text-gray-800 mb-2">Enjoyed your visit?</h2>
          <p class="text-gray-500 mb-7 max-w-sm mx-auto text-sm leading-relaxed">
            A Google review means the world to a small independent café. It takes 30 seconds and helps other visitors find us.
          </p>
          <a href="https://search.google.com/local/writereview?placeid=ChIJIeBvYUN42UcRWsRJ8xkySJE"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-3 px-8 py-3.5 bg-[#4285F4] hover:bg-[#3367d6] text-white font-bold rounded-full shadow-lg transition-colors text-sm">
            <!-- Google G icon -->
            <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#fff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#fff" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#fff" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#fff" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Leave a Google Review
          </a>
        </div>
      </section>

    </main>

    <!-- ══════════════════════════ MOBILE STICKY CALL / DIRECTIONS BAR -->
    <div class="fixed bottom-0 inset-x-0 z-50 sm:hidden bg-white border-t border-gray-200 shadow-2xl"
         aria-label="Quick contact">
      <div class="grid grid-cols-2 divide-x divide-gray-200">
        <a href="tel:+441394276305"
           class="flex items-center justify-center gap-2 py-3.5 text-brand-navy font-bold text-sm active:bg-gray-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call Us
        </a>
        <a href="https://maps.google.com/?q=The+Ferry+Cafe+Felixstowe+Ferry+IP11+9RZ"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-2 py-3.5 bg-brand-navy text-white font-bold text-sm active:bg-[#243f52]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Get Directions
        </a>
      </div>
    </div>
    <div class="h-14 sm:hidden" aria-hidden="true"></div>

    <Footer />
  </body>
</html>
