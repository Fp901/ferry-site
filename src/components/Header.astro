---
---
<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="container mx-auto px-4 py-2 flex items-center justify-between gap-4">

    <!-- Logo (white header lets the white-bg logo blend in) -->
    <a href="/" aria-label="The Ferry Cafe – Home" class="shrink-0">
      <img
        src="/assets/logo-nav.webp"
        alt="The Ferry Cafe, Felixstowe Ferry – Est. 1953"
        width="433"
        height="144"
        class="h-12 sm:h-14 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-7 text-sm font-semibold text-gray-600">
      <a href="/"        class="hover:text-brand-navy transition-colors">Home</a>
      <a href="/menu"    class="hover:text-brand-navy transition-colors">Menu</a>
      <a href="/about"   class="hover:text-brand-navy transition-colors">About</a>
      <a href="/contact" class="hover:text-brand-navy transition-colors">Contact</a>
    </nav>

    <!-- Desktop phone CTA -->
    <a href="tel:+441394276305"
       class="hidden lg:flex items-center gap-2 px-5 py-2.5 bg-brand-navy hover:bg-[#243f52] text-white text-sm font-bold rounded-full transition-colors shrink-0">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      01394 276305
    </a>

    <!-- Hamburger (mobile) -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-gray-600 rounded-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-300"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path id="icon-open"   stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        <path id="icon-close"  stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" class="hidden"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav dropdown -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-gray-100 px-4 py-3 flex flex-col gap-1"
  >
    <a href="/"        class="py-2.5 px-3 rounded-lg text-gray-700 font-medium hover:bg-gray-50 hover:text-brand-navy transition-colors">Home</a>
    <a href="/menu"    class="py-2.5 px-3 rounded-lg text-gray-700 font-medium hover:bg-gray-50 hover:text-brand-navy transition-colors">Menu</a>
    <a href="/about"   class="py-2.5 px-3 rounded-lg text-gray-700 font-medium hover:bg-gray-50 hover:text-brand-navy transition-colors">About</a>
    <a href="/contact" class="py-2.5 px-3 rounded-lg text-gray-700 font-medium hover:bg-gray-50 hover:text-brand-navy transition-colors">Contact</a>
    <a href="tel:+441394276305"
       class="mt-1 py-3 px-3 bg-brand-navy hover:bg-[#243f52] text-white rounded-lg font-bold text-sm text-center transition-colors">
      Call Us · 01394 276305
    </a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    const opening = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', !opening);
    iconOpen?.classList.toggle('hidden', opening);
    iconClose?.classList.toggle('hidden', !opening);
    toggle.setAttribute('aria-expanded', String(opening));
  });
</script>
