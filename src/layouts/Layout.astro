---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, restaurantSchema } from '../lib/schema';

interface Props {
  /** Browser tab + og:title */
  title: string;
  /** Meta description (keep under 155 chars) */
  description: string;
  /** Canonical path, e.g. "/" or "/menu" */
  canonical?: string;
  /** og:image absolute URL */
  ogImage?: string;
  /** Alt text for the social share image */
  ogImageAlt?: string;
  /** og:type ("website" for most pages, "restaurant" for the homepage) */
  ogType?: string;
  /** Page-specific JSON-LD schema objects to inject into <head> */
  schemas?: object[];
}

const {
  title,
  description,
  canonical = '/',
  ogImage = `${SITE}/og-image.jpg`,
  ogImageAlt = 'Fish & chips at The Ferry Cafe, Felixstowe Ferry, serving breakfast and brunch since 1953',
  ogType = 'website',
  schemas = [],
} = Astro.props;

const canonicalUrl = `${SITE}${canonical}`;

// Restaurant/LocalBusiness data is carried on every page; merge in any
// page-specific schemas (Menu, FAQ, Breadcrumb…).
const allSchemas = [restaurantSchema, ...schemas];
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Geo signals -->
    <meta name="geo.region"    content="GB-SFK" />
    <meta name="geo.placename" content="Felixstowe, Suffolk" />
    <meta name="geo.position"  content="51.9664;1.3765" />
    <meta name="ICBM"          content="51.9664, 1.3765" />

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:site_name"   content="The Ferry Cafe" />
    <meta property="og:locale"      content="en_GB" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:image"        content={ogImage} />
    <meta property="og:image:alt"    content={ogImageAlt} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type"   content="image/jpeg" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <meta name="twitter:image:alt"   content={ogImageAlt} />

    <!-- Favicon / app icons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1a3848" />

    <!-- LocalBusiness (site-wide) + any page-specific JSON-LD schemas -->
    {allSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Slot for any extra per-page head content -->
    <slot name="head" />
  </head>

  <body class="flex flex-col min-h-screen font-sans bg-white text-gray-800">
    <Header />
    <slot />
    <!-- Mobile sticky bar spacer (pages that render the bar add this themselves) -->
    <Footer />
  </body>
</html>
